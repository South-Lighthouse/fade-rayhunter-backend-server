SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Include the domain here for production
ALLOWED_HOSTS=localhost,127.0.0.1,example.com
# Full https:// URL(s) — required for Django's CSRF check behind nginx
CSRF_TRUSTED_ORIGINS=https://example.com

# Production domain (used by init-letsencrypt.sh to obtain TLS certificate)
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com

# MySQL
DB_NAME=fade
DB_USER=fade
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=3306

# Redis (Celery broker)
REDIS_URL=redis://redis:6379/0

# File storage
UPLOAD_ROOT=/data/uploads

# Celery file scan interval (seconds)
FILE_SCAN_INTERVAL=30
